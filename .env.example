# barrier-free-meetings — Environment variables
#
# Copy this file to `.env` and fill in the keys you want to enable.
# A key is only required for the providers you actually plan to use;
# the rest can stay blank and the corresponding route will return 503.
#
# IMPORTANT: never commit a real `.env` file. It is already in `.gitignore`.
# Set these values in your shell, your hosting platform, or your local `.env`.

# --- OpenRouter (free + paid translation models) ----------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: a separate key for paid OpenRouter models. If unset, the main key
# above is reused.
OPENROUTER_PAID_API_KEY=

# --- Google AI Studio (Gemini / Gemma translation + report generation) ------
# Get a key at https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=

# --- MiniMax (alternative translation provider) --------------------------------
# Get a key from your MiniMax dashboard.
MINIMAX_API_KEY=

# --- Ollama (fully local translation, no API key required) ------------------
# The URL of a running Ollama server. Defaults to http://127.0.0.1:11434.
OLLAMA_HOST=

# --- Whisper (local speech-to-text model selection) -------------------------
# Default model loaded when the server starts. Options include "tiny", "base",
# "small", and language-prefixed variants like "tiny.en". The actual model is
# downloaded on first use by `server/setup.ts`.
DEFAULT_WHISPER_MODEL=tiny

# --- Server runtime --------------------------------------------------------
# Bind the server to all interfaces (needed for LAN/mobile access). 0.0.0.0
# opens the server to every device on your network.
HOST=127.0.0.1
PORT=3000

# Comma-separated list of origins allowed to call the API. Use the default for
# local development; expand it when deploying or wiring up mobile shells.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,capacitor://localhost

# --- Frontend overrides (Vite build-time) ----------------------------------
# VITE_API_BASE_URL and VITE_WS_BASE_URL are read by the React app at build
# time. Leave them empty for same-origin local development. Set them when the
# backend lives on a different host (e.g. when serving a hosted frontend
# against a separate API server).
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# --- Hosting platform flags ------------------------------------------------
# Set HF_SPACES=1 when running inside a Hugging Face Docker Space so the
# server uses the hosted-demo configuration (browser STT first, no local
# Ollama/Whisper setup).
HF_SPACES=0

# Disable the first-run auto-setup (model downloads, Ollama install) when
# running inside a pre-baked container. The default is "0".
DISABLE_AUTO_SETUP=0
